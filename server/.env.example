# Server Configuration
PORT=3001
NODE_ENV=development

# Database (PostgreSQL via Docker on port 5433)
DATABASE_URL=postgresql://pagepulser:pagepulser_dev_password@localhost:5433/pagepulser

# JWT Secret (generate with: openssl rand -base64 64)
# Must be at least 32 characters
JWT_SECRET=your-64-character-minimum-secret-key-here-generate-securely

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# Email — SMTP (Mailpit for local dev, UI at http://localhost:8025)
# When SMTP_HOST is set, emails go via SMTP instead of Resend
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=

# Email (Resend) — production. Only used when SMTP_HOST is not set.
# Leave empty for console logging in dev.
RESEND_API_KEY=
EMAIL_FROM=PagePulser <noreply@pagepulser.com>

# Resend Webhook Secret (for email event tracking)
# Get from Resend dashboard → Webhooks → Signing Secret
RESEND_WEBHOOK_SECRET=

# Application URL (for email links)
APP_URL=http://localhost:3000

# Stripe (test mode keys — create products/prices in Stripe Dashboard first)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_COUPON_EARLY_ACCESS=

# Tier pricing (used for analytics — should match Stripe plan prices)
TIER_PRICE_STARTER=19
TIER_PRICE_PRO=49
TIER_PRICE_AGENCY=99
TIER_PRICE_ENTERPRISE=199

# OAuth — Google (get at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Facebook (get at https://developers.facebook.com/apps)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Google Custom Search API (for Index Exposure / dorking feature)
# Free tier: 100 queries/day. Get keys at https://developers.google.com/custom-search/v1/overview
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
