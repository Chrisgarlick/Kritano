{
  "name": "kritano-server",
  "version": "1.0.0",
  "description": "kritano backend server",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "concurrently -n api,worker,client -c blue,green,magenta \"npm run dev\" \"while true; do npm run worker; echo '[worker] Restarting in 2s...'; sleep 2; done\" \"npm run dev --prefix ../client\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "tsx src/worker.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "migrate": "tsx src/db/migrate.ts migrate",
    "migrate:refresh": "tsx src/db/migrate.ts refresh",
    "migrate:status": "tsx src/db/migrate.ts status",
    "migrate:adopt": "tsx src/db/migrate.ts adopt",
    "seed": "tsx src/db/seed.ts",
    "migrate:seed": "tsx src/db/migrate.ts migrate && tsx src/db/seed.ts",
    "prospects": "tsx src/cold-prospect-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@sentry/node": "^10.43.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "argon2": "^0.31.2",
    "axe-core": "^4.11.1",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "croner": "^10.0.1",
    "dompurify": "^3.3.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsdom": "^29.0.1",
    "jsonwebtoken": "^9.0.2",
    "mjml": "^4.18.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.3",
    "playwright": "^1.58.0",
    "puppeteer": "^24.40.0",
    "resend": "^2.0.0",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^28.0.1",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.10",
    "@types/pg": "^8.10.9",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^4.0.18"
  }
}
