{
  "name": "pagepulser-server",
  "version": "1.0.0",
  "description": "pagepulser backend server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "concurrently -n api,client -c blue,magenta \"npm run dev\" \"npm run dev --prefix ../client\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "worker:dev": "tsx watch src/worker.ts",
    "migrate": "tsx src/db/migrate.ts migrate",
    "migrate:refresh": "tsx src/db/migrate.ts refresh",
    "migrate:status": "tsx src/db/migrate.ts status",
    "migrate:adopt": "tsx src/db/migrate.ts adopt",
    "seed": "tsx src/db/seed.ts",
    "migrate:seed": "tsx src/db/migrate.ts migrate && tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "argon2": "^0.31.2",
    "axe-core": "^4.8.3",
    "cheerio": "^1.0.0-rc.12",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.3",
    "playwright": "^1.40.1",
    "resend": "^2.0.0",
    "stripe": "^20.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.10",
    "@types/pg": "^8.10.9",
    "concurrently": "^9.2.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^4.0.18"
  }
}
