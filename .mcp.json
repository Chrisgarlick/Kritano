{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp",
        "--browser-url",
        "http://127.0.0.1:9222"
      ]
    },
    "kritano": {
      "command": "npx",
      "args": [
        "tsx",
        "server/src/mcp.ts"
      ],
      "env": {
        "KRITANO_API_KEY": ""
      }
    }
  }
}
